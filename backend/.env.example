NODE_ENV=development
PORT=8081
FRONTEND_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/legal-document-analyzer
JWT_SECRET=replace-with-at-least-32-random-characters
ENABLE_DEMO_ACCOUNT=true
DEMO_EMAIL=xyz@gmail.com
DEMO_PASSWORD=123456

# Optional: live analysis is disabled gracefully when omitted.
# Create a key in Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: Redis improves caching. The current controller is safe without it.
REDIS_URL=redis://localhost:6379

# Portfolio safety/cost controls
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=3
MAX_DOCUMENT_PAGES=80
MAX_DOCUMENT_TEXT_CHARS=140000
ANALYSIS_CHUNK_CHARS=12000
ANALYSIS_MAX_CHUNKS=12
ANALYSIS_CHUNK_OUTPUT_TOKENS=900
ANALYSIS_FINAL_OUTPUT_TOKENS=1800
ANALYSES_PER_USER_PER_HOUR=5
# 1 = one global live analysis per UTC day. Set 0 only for private development.
DAILY_LIVE_ANALYSIS_LIMIT=1
